<Window x:Class="CookieClicker.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CookieClicker"
        mc:Ignorable="d"
        Title="ShopWindow" Height="450" Width="800">
    <Grid>
        <TextBox HorizontalAlignment="Left" Margin="72,26,0,0" TextWrapping="Wrap" Text="Lepší Kurzor" VerticalAlignment="Top" Width="71" TextChanged="TextBox_TextChanged"/>
        <Button x:Name="LepšiKurzorButton" Content="Button" HorizontalAlignment="Left" Margin="72,111,0,0" VerticalAlignment="Top" Width="71" Click="Button_Click"/>
        <Label x:Name="LepšíKurzorCena" Content="Cena: 10" HorizontalAlignment="Left" Margin="80,80,0,0" VerticalAlignment="Top"/>
        <Label Content="Zvýší počet sušenek za klik o 1" HorizontalAlignment="Left" Margin="22,49,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="255,26,0,0" TextWrapping="Wrap" Text="Dvojité Kliknutí" VerticalAlignment="Top" Width="95" TextChanged="TextBox_TextChanged" RenderTransformOrigin="0.5,0.5">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="-0.812"/>
                    <RotateTransform/>
                    <TranslateTransform Y="-0.503"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <Button x:Name="DvojiteKliknutiButton" Content="Button" HorizontalAlignment="Left" Margin="264,111,0,0" VerticalAlignment="Top" Width="71" Click="Button_Click2"/>
        <Label x:Name="LepšíKurzorCena_Kopírovat" Content="Cena: 50" HorizontalAlignment="Left" Margin="272,80,0,0" VerticalAlignment="Top"/>
        <Label Content="Zvýší počet sušenek za klik o 5" HorizontalAlignment="Left" Margin="214,49,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="453,26,0,0" TextWrapping="Wrap" Text="Babička" VerticalAlignment="Top" Width="52" TextChanged="TextBox_TextChanged" RenderTransformOrigin="0.5,0.5">
            <TextBox.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="-0.812"/>
                    <RotateTransform/>
                    <TranslateTransform Y="-0.503"/>
                </TransformGroup>
            </TextBox.RenderTransform>
        </TextBox>
        <Button x:Name="DvojiteKliknutiButton_Kopírovat" Content="Button" HorizontalAlignment="Left" Margin="440,111,0,0" VerticalAlignment="Top" Width="71" Click="Button_Click2"/>
        <Label x:Name="LepšíKurzorCena_Kopírovat1" Content="Cena: 50" HorizontalAlignment="Left" Margin="448,80,0,0" VerticalAlignment="Top"/>
        <Label Content="Zvýší počet sušenek za klik o 5" HorizontalAlignment="Left" Margin="390,49,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
